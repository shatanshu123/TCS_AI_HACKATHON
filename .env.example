FLASK_ENV=development
FLASK_DEBUG=1
HOST=127.0.0.1
PORT=5000
STORAGE_DIR=storage
LLM_PROVIDER=local

# To use your API key, copy this file to .env and switch:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini

# Event GenAI Lab / LangChain provider:
# LLM_PROVIDER=genailab
# GENAILAB_API_KEY=sk-your-key-here
GENAILAB_BASE_URL=https://genailab.tcs.in
GENAILAB_MODEL=azure_ai/genailab-maas-DeepSeek-V3-0324
GENAILAB_VERIFY_SSL=false
